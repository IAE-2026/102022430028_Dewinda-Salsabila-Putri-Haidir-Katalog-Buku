{
  "openapi": "3.0.0",
  "info": {
    "title": "Catalog Service API",
    "version": "1.0.0",
    "description": "Service Katalog Buku - Tugas 2 IAE (102022430028 - Dewinda Salsabila Putri Haidir)"
  },
  "servers": [
    {
      "url": "http://localhost:8002",
      "description": "Local Docker Server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/api/v1/books": {
      "get": {
        "summary": "Mengambil semua data buku",
        "tags": ["Books"],
        "responses": {
          "200": {
            "description": "Data buku berhasil diambil",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Data buku berhasil diambil." },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Book" }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "service_name": { "type": "string", "example": "catalog-service" },
                        "api_version": { "type": "string", "example": "v1" },
                        "total": { "type": "integer", "example": 5 }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Menambahkan buku baru",
        "tags": ["Books"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "author", "isbn", "publisher", "year", "stock"],
                "properties": {
                  "title": { "type": "string", "example": "Belajar Laravel" },
                  "author": { "type": "string", "example": "John Doe" },
                  "isbn": { "type": "string", "example": "978-602-1234-56-7" },
                  "publisher": { "type": "string", "example": "Penerbit Informatika" },
                  "year": { "type": "integer", "example": 2024 },
                  "stock": { "type": "integer", "example": 10 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Buku berhasil ditambahkan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Buku berhasil ditambahkan." },
                    "data": { "$ref": "#/components/schemas/Book" },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "service_name": { "type": "string", "example": "catalog-service" },
                        "api_version": { "type": "string", "example": "v1" }
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validasi gagal",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/books/{id}": {
      "get": {
        "summary": "Mengambil detail buku berdasarkan ID",
        "tags": ["Books"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detail buku berhasil diambil",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Detail buku berhasil diambil." },
                    "data": { "$ref": "#/components/schemas/Book" },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "service_name": { "type": "string", "example": "catalog-service" },
                        "api_version": { "type": "string", "example": "v1" }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Buku tidak ditemukan",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-IAE-KEY",
        "description": "Masukkan NIM kamu (102022430028) disini"
      }
    },
    "schemas": {
      "Book": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "title": { "type": "string", "example": "Belajar Laravel" },
          "author": { "type": "string", "example": "John Doe" },
          "isbn": { "type": "string", "example": "978-602-1234-56-7" },
          "publisher": { "type": "string", "example": "Penerbit Informatika" },
          "year": { "type": "integer", "example": 2024 },
          "stock": { "type": "integer", "example": 10 },
          "available_stock": { "type": "integer", "example": 10 },
          "receipt_number": { "type": "string", "nullable": true, "example": "RCP-12345" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "success" },
          "message": { "type": "string", "example": "Data retrieved successfully" },
          "data": { "type": "object" },
          "meta": {
            "type": "object",
            "properties": {
              "service_name": { "type": "string", "example": "catalog-service" },
              "api_version": { "type": "string", "example": "v1" }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "error" },
          "message": { "type": "string", "example": "Detail pesan kesalahan" },
          "errors": { "type": "object", "nullable": true }
        }
      }
    }
  }
}
